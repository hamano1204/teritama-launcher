<Window x:Class="SuikaTextExpander.Views.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:SuikaTextExpander.Models"
        xmlns:local="clr-namespace:SuikaTextExpander.Views"
        mc:Ignorable="d"
        Title="Suika Text Expander" Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F9F9F9"
        FontFamily="Segoe UI, Microsoft YaHei, Meiryo">
    <Window.Resources>
        <local:FolderIconConverter x:Key="FolderIconConverter"/>

        <!-- Color Palette -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#0078D4"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#666666"/>
        <SolidColorBrush x:Key="CardBackground" Color="White"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E5E5E5"/>

        <!-- Card Style -->
        <Style x:Key="SettingCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#D0D0D0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#EAEAEA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Navigation RadioButton Style -->
        <Style x:Key="NavLink" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" Background="Transparent" CornerRadius="6" Margin="0,2" Padding="12,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="Icon" Text="{TemplateBinding Tag}" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#E9F4FF"/>
                                <Setter Property="Foreground" Value="#0078D4"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Navigation Sidebar -->
        <Border Background="#F3F3F3" BorderBrush="#E5E5E5" BorderThickness="0,0,1,0">
            <Grid Margin="15,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Suika" FontSize="24" FontWeight="Bold" Foreground="#0078D4" Margin="10,0,0,5"/>
                    <TextBlock Text="Text Expander" FontSize="12" Foreground="#888" Margin="10,0,0,30"/>

                    <RadioButton Content="定型文の編集" IsChecked="True" Style="{StaticResource NavLink}" Tag="&#xE70F;" x:Name="NavSnippets" Checked="Nav_Checked"/>
                    <RadioButton Content="全般設定" Style="{StaticResource NavLink}" Tag="&#xE713;" x:Name="NavSettings" Checked="Nav_Checked"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="5">
                     <TextBlock Text="v1.0.0" Foreground="#AAA" FontSize="10" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. Snippets Section -->
            <Grid x:Name="SnippetsSection">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Snippet List Card -->
                <Border Style="{StaticResource SettingCard}" Grid.Column="0" Margin="0,0,15,0" Padding="0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="15,12" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                            <TextBlock Text="定型文ツリー" FontWeight="SemiBold" Foreground="#333"/>
                        </Border>
                        
                        <Border DockPanel.Dock="Bottom" Background="#F9F9F9" Padding="5" CornerRadius="0,0,8,8">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="&#xE710;" FontFamily="Segoe MDL2 Assets" ToolTip="追加" Style="{StaticResource ModernButton}" Width="32" Height="32" Margin="2" Click="AddButton_Click"/>
                                <Button Content="&#xE8B7;" FontFamily="Segoe MDL2 Assets" ToolTip="フォルダ" Style="{StaticResource ModernButton}" Width="32" Height="32" Margin="2" Click="AddFolderButton_Click"/>
                                <Button Content="&#xE738;" FontFamily="Segoe MDL2 Assets" ToolTip="区切り線" Style="{StaticResource ModernButton}" Width="32" Height="32" Margin="2" Click="AddSeparatorButton_Click"/>
                                <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" ToolTip="削除" Style="{StaticResource ModernButton}" Width="32" Height="32" Margin="2" Click="DeleteButton_Click"/>
                            </StackPanel>
                        </Border>

                        <TreeView x:Name="SnippetTree" BorderThickness="0" Background="Transparent" Padding="10"
                                  SelectedItemChanged="SnippetTree_SelectedItemChanged"
                                  AllowDrop="True"
                                  PreviewMouseLeftButtonDown="SnippetTree_PreviewMouseLeftButtonDown"
                                  MouseMove="SnippetTree_MouseMove"
                                  DragOver="SnippetTree_DragOver"
                                  Drop="SnippetTree_Drop">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="True"/>
                                    <Setter Property="Padding" Value="5,3"/>
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate DataType="{x:Type models:SnippetNode}" ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Converter={StaticResource FolderIconConverter}}" Margin="0,0,8,0" Opacity="0.6"/>
                                        <TextBlock Text="{Binding Title}"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </DockPanel>
                </Border>

                <!-- Editor Card -->
                <Border Style="{StaticResource SettingCard}" Grid.Column="1">
                    <Grid>
                        <Grid x:Name="EditorGrid" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="定型文の編集" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

                            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                                <TextBlock Text="タイトル" Foreground="{StaticResource SecondaryText}" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="TitleBox" Padding="8" BorderBrush="#DDD" TextChanged="TitleBox_TextChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Margin="0,0,0,15">
                                <DockPanel>
                                    <TextBlock Text="本文" Foreground="{StaticResource SecondaryText}" FontSize="12" VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="日付" Click="InsertTagButton_Click" Tag="{}{{now:yyyy/MM/dd}}" Style="{StaticResource ModernButton}" FontSize="10" Padding="8,2" Margin="0,0,5,0"/>
                                        <Button Content="時刻" Click="InsertTagButton_Click" Tag="{}{{now:HH:mm}}" Style="{StaticResource ModernButton}" FontSize="10" Padding="8,2" Margin="0,0,5,0"/>
                                    </StackPanel>
                                </DockPanel>
                            </StackPanel>

                            <TextBox x:Name="ContentBox" Grid.Row="3" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" 
                                     Padding="10" BorderBrush="#DDD" AcceptsTab="True" TextChanged="ContentBox_TextChanged"/>
                        </Grid>

                        <!-- Empty State -->
                        <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.5">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <TextBlock Text="アイテムを選択して編集" FontSize="14" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- 2. Settings Section -->
            <ScrollViewer x:Name="SettingsSection" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                    <TextBlock Text="アプリケーション設定" FontSize="20" FontWeight="Bold" Margin="0,0,0,25"/>

                    <Border Style="{StaticResource SettingCard}">
                        <StackPanel>
                            <TextBlock Text="起動設定" FontWeight="SemiBold" Margin="0,0,0,15"/>
                            <DockPanel>
                                <StackPanel>
                                    <TextBlock Text="自動起動" FontWeight="Medium"/>
                                    <TextBlock Text="Windowsログイン時に自動的に起動します" FontSize="12" Foreground="#888"/>
                                </StackPanel>
                                <CheckBox x:Name="AutoStartCheckBox" HorizontalAlignment="Right" VerticalAlignment="Center" Click="AutoStartCheckBox_Click" Style="{StaticResource {x:Type CheckBox}}"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingCard}">
                        <StackPanel>
                            <TextBlock Text="ホットキー設定" FontWeight="SemiBold" Margin="0,0,0,15"/>
                            <TextBlock Text="メニューを呼び出すキーの組み合わせを設定します" FontSize="12" Foreground="#888" Margin="0,0,0,15"/>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="ModifierCtrl" Content="Ctrl" Margin="0,0,12,0"/>
                                <CheckBox x:Name="ModifierAlt" Content="Alt" Margin="0,0,12,0"/>
                                <CheckBox x:Name="ModifierShift" Content="Shift" Margin="0,0,12,0"/>
                                <CheckBox x:Name="ModifierWin" Content="Win" Margin="0,0,12,0"/>
                                <TextBlock Text="+" VerticalAlignment="Center" Margin="5,0,12,0" Opacity="0.5"/>
                                <TextBox x:Name="HotkeyCharBox" Width="45" Padding="8" MaxLength="1" HorizontalContentAlignment="Center" TextChanged="HotkeyCharBox_TextChanged"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingCard}">
                        <StackPanel>
                            <TextBlock Text="データ管理" FontWeight="SemiBold" Margin="0,0,0,15"/>
                            <TextBlock Text="データのバックアップや移行のためのファイル操作" FontSize="12" Foreground="#888" Margin="0,0,0,15"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="エクスポート" Click="ExportButton_Click" Style="{StaticResource ModernButton}" Margin="0,0,10,0"/>
                                <Button Content="インポート" Click="ImportButton_Click" Style="{StaticResource ModernButton}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom Action Bar -->
            <Border Grid.Row="1" Margin="0,20,0,0" Padding="0,15,0,0" BorderBrush="#EEE" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="キャンセル" Width="120" Style="{StaticResource ModernButton}" Margin="0,0,12,0" Click="CancelButton_Click"/>
                    <Button Content="設定を保存して閉じる" Width="200" Style="{StaticResource PrimaryButton}" Click="SaveButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
