<Window x:Class="SuikaTextExpander.Views.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:SuikaTextExpander.Models"
        xmlns:local="clr-namespace:SuikaTextExpander.Views"
        mc:Ignorable="d"
        Title="定型文編集 - Suika Text Expander" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3">
    <Window.Resources>
        <local:FolderIconConverter x:Key="FolderIconConverter"/>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar: TreeView -->
        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="5" Margin="0,0,10,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                    <Button Content="追加" Width="50" Margin="2" Click="AddButton_Click"/>
                    <Button Content="フォルダ" Width="50" Margin="2" Click="AddFolderButton_Click"/>
                    <Button Content="区切り線" Width="60" Margin="2" Click="AddSeparatorButton_Click"/>
                    <Button Content="削除" Width="50" Margin="2" Click="DeleteButton_Click"/>
                </StackPanel>
                <TreeView x:Name="SnippetTree" BorderThickness="0" 
                          SelectedItemChanged="SnippetTree_SelectedItemChanged"
                          AllowDrop="True"
                          PreviewMouseLeftButtonDown="SnippetTree_PreviewMouseLeftButtonDown"
                          MouseMove="SnippetTree_MouseMove"
                          DragOver="SnippetTree_DragOver"
                          Drop="SnippetTree_Drop">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type models:SnippetNode}" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Converter={StaticResource FolderIconConverter}}" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding Title}"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </DockPanel>
        </Border>

        <!-- Editor Area -->
        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20">
            <Grid x:Name="EditorGrid" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="タイトル" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="TitleBox" Grid.Row="1" Margin="0,0,0,15" Padding="5"
                         TextChanged="TitleBox_TextChanged"/>

                <TextBlock Text="内容" FontWeight="Bold" Grid.Row="2" Margin="0,0,0,5"/>
                <TextBox x:Name="ContentBox" Grid.Row="2" Margin="0,25,0,0" 
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Padding="5"
                         TextChanged="ContentBox_TextChanged"
                         AcceptsTab="True"/>

                <Button Content="保存して閉じる" Grid.Row="3" HorizontalAlignment="Right" 
                        Padding="20,8" Margin="0,15,0,0" Click="SaveButton_Click"/>

                <Border Grid.Row="3" BorderBrush="#DDD" BorderThickness="0,1,0,0" Margin="0,15,0,0" Padding="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ホットキー設定: Win + Alt + " VerticalAlignment="Center"/>
                        <TextBox x:Name="HotkeyCharBox" Width="40" Margin="5,0" Padding="3" MaxLength="1"
                                 HorizontalContentAlignment="Center" VerticalAlignment="Center"
                                 TextChanged="HotkeyCharBox_TextChanged"/>
                        <TextBlock Text="(英数字1文字)" VerticalAlignment="Center" Foreground="#888" FontSize="11"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
