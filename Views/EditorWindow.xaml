<Window x:Class="SuikaTextExpander.Views.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:SuikaTextExpander.Models"
        xmlns:local="clr-namespace:SuikaTextExpander.Views"
        mc:Ignorable="d"
        Title="Suika Text Expander" Height="650" Width="920"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3"
        FontFamily="Segoe UI Variable Text, Segoe UI, Meiryo"
        Icon="/suika_icon.png">
    <Window.Resources>
        <local:FolderIconConverter x:Key="FolderIconConverter"/>

        <!-- Windows 11 Accent & Neutral Colors -->
        <SolidColorBrush x:Key="Win11Accent" Color="#0067C0"/>
        <SolidColorBrush x:Key="Win11AccentHover" Color="#005AAB"/>
        <SolidColorBrush x:Key="Win11TextPrimary" Color="#000000"/>
        <SolidColorBrush x:Key="Win11TextSecondary" Color="#5F5F5F"/>
        <SolidColorBrush x:Key="Win11CardBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Win11CardBorder" Color="#E5E5E5"/>
        <SolidColorBrush x:Key="Win11SidebarBackground" Color="#EEEEEE"/>
        <SolidColorBrush x:Key="Win11SidebarBorder" Color="#E0E0E0"/>

        <!-- Windows 11 Card Style (Fluent Card) -->
        <Style x:Key="SettingCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Win11CardBackground}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource Win11CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Windows 11 Standard Button Style (Fluent Button) -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#FDFFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource Win11TextPrimary}"/>
            <Setter Property="BorderBrush" Value="#C3C3C3"/>
            <Setter Property="BorderThickness" Value="1,1,1,1.5"/> <!-- Windows 11 3D bottom-border hint -->
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="buttonBorder" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F9F9F9"/>
                                <Setter Property="BorderBrush" Value="#B5B5B5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#F3F3F3"/>
                                <Setter Property="BorderBrush" Value="#B5B5B5"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Windows 11 Accent Button Style (Fluent Primary Button) -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Win11Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#005AAB"/>
            <Setter Property="BorderThickness" Value="0,0,0,1.5"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="buttonBorder" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Win11AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004D93"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Windows 11 Sidebar Navigation Link Style -->
        <Style x:Key="NavLink" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" Background="Transparent" CornerRadius="4" Margin="4,2" Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Left Indicator Bar for Windows 11 style -->
                                <Border x:Name="Indicator" Width="3" Height="16" Background="{StaticResource Win11Accent}" CornerRadius="1.5" HorizontalAlignment="Left" Margin="-12,0,8,0" Visibility="Collapsed"/>
                                
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock x:Name="Icon" Text="{TemplateBinding Tag}" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FDFFFFFF"/> <!-- Pure White active block -->
                                <Setter Property="Foreground" Value="{StaticResource Win11TextPrimary}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#EAEAEA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Windows 11 Flat Text Field Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FDFFFFFF"/>
            <Setter Property="BorderThickness" Value="1,1,1,2"/> <!-- Slightly thicker bottom border -->
            <Setter Property="BorderBrush" Value="#C3C3C3"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Foreground" Value="{StaticResource Win11TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Win11Accent}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1,1,1,2"/>
                                <Setter Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation -->
        <Border Background="{StaticResource Win11SidebarBackground}" BorderBrush="{StaticResource Win11SidebarBorder}" BorderThickness="0,0,1,0">
            <Grid Margin="10,25,10,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Suika" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Win11TextPrimary}" Margin="15,0,0,2"/>
                    <TextBlock Text="Text Expander" FontSize="11" Foreground="{StaticResource Win11TextSecondary}" Margin="16,0,0,30"/>

                    <RadioButton Content="定型文の編集" IsChecked="True" Style="{StaticResource NavLink}" Tag="&#xE70F;" x:Name="NavSnippets" Checked="Nav_Checked" Foreground="{StaticResource Win11TextPrimary}"/>
                    <RadioButton Content="全般設定" Style="{StaticResource NavLink}" Tag="&#xE713;" x:Name="NavSettings" Checked="Nav_Checked" Foreground="{StaticResource Win11TextPrimary}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="5">
                     <TextBlock Text="v1.0.0" Foreground="{StaticResource Win11TextSecondary}" FontSize="10" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. Snippets Section -->
            <Grid x:Name="SnippetsSection">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="290"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Snippet List Card -->
                <Border Style="{StaticResource SettingCard}" Grid.Column="0" Margin="0,0,15,0" Padding="0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="16,12" BorderBrush="{StaticResource Win11CardBorder}" BorderThickness="0,0,0,1">
                            <TextBlock Text="定型文ツリー" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Win11TextSecondary}"/>
                        </Border>
                        
                        <Border DockPanel.Dock="Bottom" Background="#FAFAFA" Padding="8" CornerRadius="0,0,8,8" BorderBrush="{StaticResource Win11CardBorder}" BorderThickness="0,1,0,0">
                            <UniformGrid Columns="4">
                                <Button Content="&#xE710;" FontFamily="Segoe MDL2 Assets" ToolTip="追加" Style="{StaticResource ModernButton}" Height="32" Margin="2" Click="AddButton_Click"/>
                                <Button Content="&#xE8F4;" FontFamily="Segoe MDL2 Assets" ToolTip="フォルダ" Style="{StaticResource ModernButton}" Height="32" Margin="2" Click="AddFolderButton_Click"/>
                                <Button Content="&#xE738;" FontFamily="Segoe MDL2 Assets" ToolTip="区切り線" Style="{StaticResource ModernButton}" Height="32" Margin="2" Click="AddSeparatorButton_Click"/>
                                <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" ToolTip="削除" Style="{StaticResource ModernButton}" Height="32" Margin="2" Click="DeleteButton_Click"/>
                            </UniformGrid>
                        </Border>

                        <TreeView x:Name="SnippetTree" BorderThickness="0" Background="Transparent" Padding="8"
                                  SelectedItemChanged="SnippetTree_SelectedItemChanged"
                                  AllowDrop="True"
                                  PreviewMouseLeftButtonDown="SnippetTree_PreviewMouseLeftButtonDown"
                                  MouseMove="SnippetTree_MouseMove"
                                  DragOver="SnippetTree_DragOver"
                                  Drop="SnippetTree_Drop">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="True"/>
                                    <Setter Property="Padding" Value="5,4"/>
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate DataType="{x:Type models:SnippetNode}" ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Converter={StaticResource FolderIconConverter}}" Margin="0,0,8,0" Opacity="0.8" Foreground="{StaticResource Win11Accent}"/>
                                        <TextBlock Text="{Binding Title}" Foreground="{StaticResource Win11TextPrimary}"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </DockPanel>
                </Border>

                <!-- Editor Card -->
                <Border Style="{StaticResource SettingCard}" Grid.Column="1">
                    <Grid>
                        <Grid x:Name="EditorGrid" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,20">
                                <TextBlock Text="定型文の編集" FontSize="17" FontWeight="Bold" Foreground="{StaticResource Win11TextPrimary}" VerticalAlignment="Center"/>
                                <Border Height="1" Background="{StaticResource Win11CardBorder}" VerticalAlignment="Center" Margin="15,0,0,0"/>
                            </DockPanel>

                            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                                <TextBlock Text="タイトル" Foreground="{StaticResource Win11TextSecondary}" FontSize="12" Margin="0,0,0,6"/>
                                <TextBox x:Name="TitleBox" TextChanged="TitleBox_TextChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                                <DockPanel>
                                    <TextBlock Text="本文" Foreground="{StaticResource Win11TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="日付を挿入" Click="InsertTagButton_Click" Tag="{}{{now:yyyy/MM/dd}}" Style="{StaticResource ModernButton}" FontSize="10" Padding="12,4" Margin="0,0,5,0"/>
                                        <Button Content="時刻を挿入" Click="InsertTagButton_Click" Tag="{}{{now:HH:mm}}" Style="{StaticResource ModernButton}" FontSize="10" Padding="12,4" Margin="0,0,5,0"/>
                                    </StackPanel>
                                </DockPanel>
                            </StackPanel>

                            <TextBox x:Name="ContentBox" Grid.Row="3" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" 
                                     AcceptsTab="True" TextChanged="ContentBox_TextChanged"/>
                        </Grid>

                        <!-- Empty State (Windows 11 Style) -->
                        <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                            <Border Width="60" Height="60" CornerRadius="30" Background="#ECECEC" Margin="0,0,0,16" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="{StaticResource Win11TextSecondary}" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="編集するアイテムの選択" FontSize="15" FontWeight="Bold" Foreground="{StaticResource Win11TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="左の定型文ツリーから項目を選択すると、ここに詳細な編集画面が表示されます。" 
                                       FontSize="12" Foreground="{StaticResource Win11TextSecondary}" TextAlignment="Center" MaxWidth="300" LineHeight="17"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- 2. Settings Section -->
            <ScrollViewer x:Name="SettingsSection" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                    <TextBlock Text="環境設定" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Win11TextPrimary}" Margin="0,0,0,25"/>

                    <Border Style="{StaticResource SettingCard}">
                        <StackPanel>
                            <TextBlock Text="起動設定" FontWeight="Bold" Foreground="{StaticResource Win11TextPrimary}" Margin="0,0,0,15"/>
                            <DockPanel>
                                <StackPanel>
                                    <TextBlock Text="自動起動" FontWeight="Normal" Foreground="{StaticResource Win11TextPrimary}"/>
                                    <TextBlock Text="Windowsログイン時に自動的に起動します" FontSize="11" Foreground="{StaticResource Win11TextSecondary}"/>
                                </StackPanel>
                                <CheckBox x:Name="AutoStartCheckBox" HorizontalAlignment="Right" VerticalAlignment="Center" Click="AutoStartCheckBox_Click"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingCard}">
                        <StackPanel>
                            <TextBlock Text="キーボードショートカット設定" FontWeight="Bold" Foreground="{StaticResource Win11TextPrimary}" Margin="0,0,0,15"/>
                            <TextBlock Text="メニューを呼び出すキーの組み合わせを設定します（入力欄をクリックしてキーを押してください）" FontSize="11" Foreground="{StaticResource Win11TextSecondary}" Margin="0,0,0,15"/>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="ModifierCtrl" Content="Ctrl" Margin="0,0,12,0"/>
                                <CheckBox x:Name="ModifierAlt" Content="Alt" Margin="0,0,12,0"/>
                                <CheckBox x:Name="ModifierShift" Content="Shift" Margin="0,0,12,0"/>
                                <CheckBox x:Name="ModifierWin" Content="Win" Margin="0,0,12,0"/>
                                <TextBlock Text="+" VerticalAlignment="Center" Margin="5,0,12,0" Opacity="0.5"/>
                                <TextBox x:Name="HotkeyCharBox" Width="180" 
                                         HorizontalContentAlignment="Center" VerticalContentAlignment="Center" 
                                         IsReadOnly="True" Focusable="True" Background="White" BorderBrush="{StaticResource Win11SidebarBorder}" 
                                         FontWeight="Bold" Foreground="{StaticResource Win11Accent}" FontSize="13" Cursor="Hand"
                                         GotFocus="HotkeyCharBox_GotFocus" LostFocus="HotkeyCharBox_LostFocus" 
                                         PreviewKeyDown="HotkeyCharBox_PreviewKeyDown"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingCard}">
                        <StackPanel>
                            <TextBlock Text="データ管理" FontWeight="Bold" Foreground="{StaticResource Win11TextPrimary}" Margin="0,0,0,15"/>
                            <TextBlock Text="データのバックアップや移行のためのファイル操作" FontSize="11" Foreground="{StaticResource Win11TextSecondary}" Margin="0,0,0,15"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="エクスポート" Click="ExportButton_Click" Style="{StaticResource ModernButton}" Margin="0,0,10,0"/>
                                <Button Content="インポート" Click="ImportButton_Click" Style="{StaticResource ModernButton}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom Action Bar -->
            <Border Grid.Row="1" Margin="0,20,0,0" Padding="0,15,0,0" BorderBrush="{StaticResource Win11CardBorder}" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="キャンセル" Width="120" Style="{StaticResource ModernButton}" Margin="0,0,12,0" Click="CancelButton_Click"/>
                    <Button Content="保存" Width="120" Style="{StaticResource PrimaryButton}" Click="SaveButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
