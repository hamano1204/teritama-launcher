<Window x:Class="SuikaTextExpander.Views.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:SuikaTextExpander.Models"
        xmlns:local="clr-namespace:SuikaTextExpander.Views"
        mc:Ignorable="d"
        Title="定型文編集 - Suika Text Expander" Height="650" Width="750"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3">
    <Window.Resources>
        <local:FolderIconConverter x:Key="FolderIconConverter"/>
        
        <!-- Modern TabControl Style -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="14" FontWeight="SemiBold" Margin="10,5"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#0078D4"/>
                    <Setter Property="BorderBrush" Value="#0078D4"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="False">
                    <Setter Property="Foreground" Value="#666"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="1">
            <!-- Snippet Editor Tab -->
            <TabItem Header="定型文の編集">
                <Grid Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sidebar: TreeView -->
                    <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="5" Margin="0,0,10,0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                                <Button Content="追加" Width="50" Margin="2" Click="AddButton_Click"/>
                                <Button Content="フォルダ" Width="50" Margin="2" Click="AddFolderButton_Click"/>
                                <Button Content="区切り線" Width="60" Margin="2" Click="AddSeparatorButton_Click"/>
                                <Button Content="削除" Width="50" Margin="2" Click="DeleteButton_Click"/>
                            </StackPanel>
                            <TreeView x:Name="SnippetTree" BorderThickness="0" 
                                      SelectedItemChanged="SnippetTree_SelectedItemChanged"
                                      AllowDrop="True"
                                      PreviewMouseLeftButtonDown="SnippetTree_PreviewMouseLeftButtonDown"
                                      MouseMove="SnippetTree_MouseMove"
                                      DragOver="SnippetTree_DragOver"
                                      Drop="SnippetTree_Drop">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="True"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate DataType="{x:Type models:SnippetNode}" ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Converter={StaticResource FolderIconConverter}}" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding Title}"/>
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </DockPanel>
                    </Border>

                    <!-- Editor Area -->
                    <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20">
                        <Grid x:Name="EditorGrid" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="タイトル" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox x:Name="TitleBox" Grid.Row="1" Margin="0,0,0,15" Padding="5"
                                     TextChanged="TitleBox_TextChanged"/>

                            <Border Grid.Row="2" Margin="0,5,0,0">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="タグ挿入: " VerticalAlignment="Center" Foreground="#666" FontSize="11" Margin="0,0,5,0"/>
                                        <Button Content="日付 (2026/01/01)" Click="InsertTagButton_Click" Tag="{}{{now:yyyy/MM/dd}}" FontSize="11" Padding="5,2" Margin="0,0,5,0" Background="#F0F0F0" BorderThickness="1"/>
                                        <Button Content="時刻 (12:34)" Click="InsertTagButton_Click" Tag="{}{{now:HH:mm}}" FontSize="11" Padding="5,2" Margin="0,0,5,0" Background="#F0F0F0" BorderThickness="1"/>
                                        <Button Content="日時 (2026/01/01 12:34)" Click="InsertTagButton_Click" Tag="{}{{now:yyyy/MM/dd HH:mm}}" FontSize="11" Padding="5,2" Margin="0,0,5,0" Background="#F0F0F0" BorderThickness="1"/>
                                    </StackPanel>
                                    <TextBox x:Name="ContentBox" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Padding="5"
                                             TextChanged="ContentBox_TextChanged" AcceptsTab="True"/>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- General Settings Tab -->
            <TabItem Header="全般設定">
                <Border Background="White" CornerRadius="8" Padding="30" Margin="0,15,0,0">
                    <StackPanel MaxWidth="500" HorizontalAlignment="Left">
                        <TextBlock Text="アプリケーション設定" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                        <GroupBox Header="起動設定" Margin="0,0,0,20" Padding="10">
                            <StackPanel>
                                <CheckBox x:Name="AutoStartCheckBox" Content="Windowsログイン時に自動的に起動する" 
                                          Margin="0,5" Click="AutoStartCheckBox_Click"/>
                                <TextBlock Text="アプリを常にバックグラウンドで待機させることができます。" 
                                           Foreground="#888" FontSize="12" Margin="25,2,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="ホットキー設定" Padding="10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="定型文メニューを表示: " VerticalAlignment="Center"/>
                                    <TextBlock Text="Win + Alt + " FontWeight="Bold" VerticalAlignment="Center" Margin="5,0"/>
                                    <TextBox x:Name="HotkeyCharBox" Width="40" Padding="5" MaxLength="1"
                                             HorizontalContentAlignment="Center" VerticalAlignment="Center"
                                             TextChanged="HotkeyCharBox_TextChanged"/>
                                </StackPanel>
                                <TextBlock Text="※変更は「保存して閉じる」をクリックした後に反映されます。" 
                                           Foreground="#888" FontSize="11" Margin="0,10,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- バックアップと復元 -->
                        <GroupBox Header="バックアップと復元" Padding="10" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="定型文と設定をファイルに書き出したり、読み込んだりできます。" 
                                           TextWrapping="Wrap" Margin="0,0,0,10" Foreground="#666" FontSize="11"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="定型文をエクスポート..." Click="ExportButton_Click" Padding="15,5" Margin="0,0,10,0"/>
                                    <Button Content="定型文をインポート..." Click="ImportButton_Click" Padding="15,5"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Common Button Bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="キャンセル" Width="100" Padding="10,8" Margin="0,0,10,0" Click="CancelButton_Click" Background="#EEE" BorderThickness="1" BorderBrush="#CCC"/>
            <Button Content="すべての設定を保存して閉じる" Padding="25,8" Click="SaveButton_Click"
                    Background="#0078D4" Foreground="White" BorderThickness="0" FontWeight="SemiBold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
